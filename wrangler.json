{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "telefiles",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "pages_build_output_dir": ".vercel/output",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "telefiles-db",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ]
}
